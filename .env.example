APP_ENV=development
PORT=9102
DATABASE_URL=postgres://postgres:postgres@localhost:9101/cool_dispatch?sslmode=disable
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=cool-dispatch-postgres
POSTGRES_DB=cool_dispatch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=9101
POSTGRES_CONTAINER_PORT=5432
# macOS 本地建议使用外置盘；Ubuntu 22.04 建议改为 /srv/cool-dispatch/postgresql
POSTGRES_DATA_DIR=/Volumes/externalHard/data/cool-dispatch/postgresql
# 应用与启动脚本默认都关闭自动迁移与 demo seed；
# 只有显式设置为 true 时才会启用。
AUTO_MIGRATE=false
SEED_DEMO_DATA=false
# 开发态若要初始化可登录的 demo 账号，必须显式提供管理员账号与密码。
SEED_ADMIN_NAME=管理員
SEED_ADMIN_PHONE=0912345678
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_TECHNICIAN_PASSWORD=change-this-technician-password
SERVE_STATIC=false
FRONTEND_ORIGIN=http://localhost:5173
LINE_CHANNEL_SECRET=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
VITE_API_BASE_URL=http://localhost:9102
FRONTEND_DIST=../dist/client
# HTTP 安全基线：显式服务端超时、Header 上限、请求体上限。
HTTP_READ_HEADER_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_IDLE_TIMEOUT_SECONDS=60
HTTP_MAX_HEADER_BYTES=1048576
MAX_JSON_BODY_BYTES=1048576
MAX_WEBHOOK_BODY_BYTES=262144
# ---------- PAYUNi 支付（信用卡 + ATM 转账） ----------
# 测试区：https://sandbox-api.payuni.com.tw
# 正式区：https://api.payuni.com.tw
PAYUNI_API_BASE_URL=https://sandbox-api.payuni.com.tw
PAYUNI_MER_ID=
PAYUNI_HASH_KEY=
PAYUNI_HASH_IV=
PAYUNI_NOTIFY_URL=
